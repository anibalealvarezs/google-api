{
    "name": "anibalealvarezs/google-api",
    "description": "Standardized Google API client for APIs Hub, supporting Search Console and Analytics data extraction.",
    "license": "MIT",
    "keywords": [
        "google-api",
        "google-search-console",
        "analytics",
        "apis-hub",
        "php"
    ],
    "homepage": "https://github.com/anibalealvarezs/google-api",
    "authors": [
        {
            "name": "Aníbal Álvarez",
            "email": "anibalealvarezs@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/anibalealvarezs/google-api/issues"
    },
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0",
        "ext-json": "*",
        "symfony/yaml": "^6.0 || ^7.0",
        "nesbot/carbon": "^2.61 || ^3.0",
        "anibalealvarezs/api-client-skeleton": "dev-main",
        "monolog/monolog": "^2.0 || ^3.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "ext-imap": "*"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://satis.anibalalvarez.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anibalealvarezs\\GoogleApi\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "doctrine/instantiator": "^1.5",
        "fakerphp/faker": "^1.20",
        "friendsofphp/php-cs-fixer": "dev-master",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9"
    },
    "scripts": {
        "phpstan": "phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": false
}
