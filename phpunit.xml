<?xml version="1.0" encoding="UTF-8"?>
<phpunit
        bootstrap="tests/bootstrap.php"
        colors="true"
        verbose="true"
        stopOnFailure="false"
        failOnRisky="true"
        failOnWarning="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">tests/Unit</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory suffix="Test.php">tests/Integration</directory>
        </testsuite>
    </testsuites>

    <coverage processUncoveredFiles="true">
        <include>
            <directory>src</directory>
        </include>
    </coverage>

    <php>
        <!-- Path to the YAML config file for integration tests.
             Leave empty to fall back to config/config.yaml, or set to a
             custom path. If the file doesn't exist, credentials will be
             read from individual GOOGLE_*, SEARCH_CONSOLE_*, etc. env vars. -->
        <env name="CONFIG_FILE" value=""/>

    </php>
</phpunit>
